# Copy to .env and fill in real values. Never commit .env.
#
# Database: use your Neon connection string (Dashboard → Connect → URI).
# The app does not use a separate "local vs Neon" mode — whatever URL you put here is the only database.
# Include ?sslmode=require for Neon.
#
# Example shape (replace USER, PASSWORD, HOST, DBNAME with your Neon values):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/DBNAME?sslmode=require
#
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require

ANTHROPIC_API_KEY=your_claude_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Google OAuth (required for login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# Optional override endpoints:
# GOOGLE_OAUTH_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
# GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
# GOOGLE_OAUTH_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo

# Comma-separated admin emails who can see maintenance tools
ADMIN_EMAILS=
# Comma-separated emails defaulted to middle_school track on first login
MIDDLE_SCHOOL_EMAILS=

# Optional PayPal donation link shown in sidebar
PAYPAL_DONATE_URL=
